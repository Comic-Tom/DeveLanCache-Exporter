{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "LanCache / DeveLanCacheUI monitoring dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "LanCache Status",
      "type": "stat",
      "targets": [{ "expr": "lancache_up", "legendFormat": "Status", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.5 },
            { "color": "green", "value": 0.8 }
          ]},
          "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 3, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Overall Cache Hit Ratio",
      "type": "stat",
      "targets": [{ "expr": "lancache_cache_hit_ratio", "legendFormat": "Hit Ratio", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "gridPos": { "h": 3, "w": 4, "x": 7, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Cache Hits",
      "type": "stat",
      "targets": [{ "expr": "lancache_total_cache_hit_bytes", "legendFormat": "Hit Bytes", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] } }
      },
      "gridPos": { "h": 3, "w": 4, "x": 11, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Cache Misses",
      "type": "stat",
      "targets": [{ "expr": "lancache_total_cache_miss_bytes", "legendFormat": "Miss Bytes", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 3, "w": 4, "x": 15, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Active Downloads (last 60s)",
      "type": "stat",
      "targets": [{ "expr": "lancache_active_downloads", "legendFormat": "Active", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }
      },
      "gridPos": { "h": 3, "w": 4, "x": 19, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Recent Events (last 100)",
      "type": "stat",
      "targets": [{ "expr": "lancache_recent_download_events_total", "legendFormat": "Events", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "Cache Performance Over Time",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Cache Hit Ratio Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "lancache_cache_hit_ratio", "legendFormat": "Overall", "refId": "A" },
        { "expr": "lancache_service_cache_hit_ratio", "legendFormat": "{{service}}", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Hit vs Miss Bytes Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(lancache_total_cache_hit_bytes[5m])", "legendFormat": "Hit rate", "refId": "A" },
        { "expr": "rate(lancache_total_cache_miss_bytes[5m])", "legendFormat": "Miss rate", "refId": "B" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 102,
      "title": "Per Service Breakdown",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "pieType": "pie"
      },
      "title": "Cache Hits by Service",
      "type": "piechart",
      "targets": [{ "expr": "lancache_service_cache_hit_bytes", "legendFormat": "{{service}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "pieType": "pie"
      },
      "title": "Cache Misses by Service",
      "type": "piechart",
      "targets": [{ "expr": "lancache_service_cache_miss_bytes", "legendFormat": "{{service}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 22,
      "options": { "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Cache Hit Bytes Over Time — by Service",
      "type": "timeseries",
      "targets": [{ "expr": "lancache_service_cache_hit_bytes", "legendFormat": "{{service}}", "refId": "A" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 103,
      "title": "Per Client Breakdown",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Hit Bytes" }, "properties": [{ "id": "custom.displayMode", "value": "gradient-gauge" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Miss Bytes" }, "properties": [{ "id": "custom.displayMode", "value": "gradient-gauge" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 30,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Hit Bytes" }]
      },
      "title": "Top Clients — Cache Hit / Miss",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Hit Bytes", "Value #B": "Miss Bytes", "client_ip": "Client IP" } } }
      ],
      "type": "table",
      "targets": [
        { "expr": "lancache_client_cache_hit_bytes", "legendFormat": "", "refId": "A", "instant": true },
        { "expr": "lancache_client_cache_miss_bytes", "legendFormat": "", "refId": "B", "instant": true }
      ]
    },

    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 31,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Hit Ratio Over Time — by Client",
      "type": "timeseries",
      "targets": [{
        "expr": "lancache_client_cache_hit_bytes / (lancache_client_cache_hit_bytes + lancache_client_cache_miss_bytes)",
        "legendFormat": "{{client_ip}}",
        "refId": "A"
      }]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["lancache", "gaming", "network"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LanCache — DeveLanCacheUI",
  "uid": "lancache-develancacheui",
  "version": 1
}
